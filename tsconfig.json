{
    "compilerOptions": {
        "target": "ES2022",
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable"
        ],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "verbatimModuleSyntax": true,
        "baseUrl": ".",
        "paths": {
            "@pilot/*": [
                "./*"
            ]
        },
        "types": [
            "chrome"
        ]
    },
    "include": [
        "browser/**/*.ts",
        "runtime/**/*.ts",
        "sdk/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}