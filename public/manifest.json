{
  "manifest_version": 3,
  "name": "Collider Pilot",
  "version": "0.1.0",
  "description": "Read-only mo:os seat: live HG frame, A3 access view-filter, LLM proposer (Ollama / Gemini via kernel-proxy), review-only previews.",

  "permissions": ["sidePanel", "storage", "activeTab", "clipboardWrite", "tabGroups"],

  "host_permissions": [
    "http://localhost:8080/*",
    "http://localhost:8000/*",
    "http://localhost:11434/*",
    "https://localhost:8443/*"
  ],

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "web_accessible_resources": [
    {
      "resources": ["sidepanel.html", "pip.html", "selftest.html"],
      "matches": ["http://localhost/*"]
    }
  ],

  "background": {
    "service_worker": "worker.js",
    "type": "module"
  },

  "action": {
    "default_title": "Open Collider Pilot",
    "default_icon": {
      "16": "icons/pilot-16.png",
      "32": "icons/pilot-32.png",
      "48": "icons/pilot-48.png",
      "128": "icons/pilot-128.png"
    }
  },

  "icons": {
    "16": "icons/pilot-16.png",
    "32": "icons/pilot-32.png",
    "48": "icons/pilot-48.png",
    "128": "icons/pilot-128.png"
  }
}
